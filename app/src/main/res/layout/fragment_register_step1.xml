<?xml version="1.0" encoding="utf-8"?>
<!--
    Paso 1: Correo + Contraseña en el mismo pantalla para que los gestores de
    contraseñas (Bitwarden, Google Autofill) detecten y guarden el par.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Título -->
        <TextView
            android:id="@+id/tvStep1Title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reg_step1_title"
            android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:lineSpacingMultiplier="1.05" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp"
            android:text="@string/reg_step1_subtitle"
            android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <!-- ── Campo Correo ── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/reg_step1_hint_email"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:hintTextColor="?attr/colorPrimary"
            app:boxStrokeColor="?attr/colorPrimary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:autofillHints="emailAddress"
                android:imeOptions="actionNext"
                android:textSize="16sp"
                android:textColor="?attr/colorOnBackground" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Error correo -->
        <TextView
            android:id="@+id/tvEmailError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="4dp"
            android:paddingHorizontal="4dp"
            android:textSize="12sp"
            android:textColor="?attr/colorError"
            android:visibility="gone" />

        <!-- ── Campo Contraseña ── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/reg_step1_hint_password"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:hintTextColor="?attr/colorPrimary"
            app:boxStrokeColor="?attr/colorPrimary"
            app:endIconMode="password_toggle"
            app:endIconTint="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:autofillHints="newPassword"
                android:imeOptions="actionDone"
                android:textSize="16sp"
                android:textColor="?attr/colorOnBackground" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Nota de diferenciación entre contraseñas -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:paddingHorizontal="4dp"
            android:text="@string/reg_step1_password_note"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:drawablePadding="4dp" />

        <!-- ── Requisitos de contraseña (chips animados) ── -->
        <LinearLayout
            android:id="@+id/requirementsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <!-- Req 1: longitud -->
            <LinearLayout
                android:id="@+id/reqLength"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/reqLengthIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_length"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Req 2: mayúscula -->
            <LinearLayout
                android:id="@+id/reqUpper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/reqUpperIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_upper"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Req 3: minúscula -->
            <LinearLayout
                android:id="@+id/reqLower"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/reqLowerIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_lower"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Req 4: número -->
            <LinearLayout
                android:id="@+id/reqNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/reqNumberIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_number"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Req 5: símbolo -->
            <LinearLayout
                android:id="@+id/reqSymbol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/reqSymbolIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_symbol"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </LinearLayout>

        <!-- Spacer empuja el botón hacia abajo -->
        <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_marginTop="24dp" />

        <!-- ── Botón Siguiente ── -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/reg_step1_btn_next"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimary"
            android:backgroundTint="?attr/colorPrimary"
            android:enabled="false"
            android:stateListAnimator="@null"
            style="@style/Widget.Material3.Button"
            app:cornerRadius="28dp" />

        <!-- Link a Login -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoToLogin"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/already_have_account"
            android:textColor="?attr/colorPrimary" />

    </LinearLayout>
</ScrollView>
