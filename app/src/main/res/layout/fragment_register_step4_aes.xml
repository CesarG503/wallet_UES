<?xml version="1.0" encoding="utf-8"?>
<!-- Paso 4: Contraseña de WALLET (AES) — diferente a la contraseña de cuenta -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Título -->

        <!-- Subtítulo diferenciador -->

        <!-- Advertencia visual — caja de diferenciación -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reg_step4_title"
            android:textAppearance="@style/TextAppearance.Material3.DisplaySmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:lineSpacingMultiplier="1.4"
            android:text="@string/reg_step4_subtitle"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="14sp" />

        <!-- ── Campo Contraseña de Wallet (AES) ── -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAesPassword"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/reg_step4_hint"
            app:boxCornerRadiusTopStart="14dp"
            app:boxCornerRadiusTopEnd="14dp"
            app:boxCornerRadiusBottomStart="14dp"
            app:boxCornerRadiusBottomEnd="14dp"
            app:hintTextColor="?attr/colorPrimary"
            app:boxStrokeColor="?attr/colorPrimary"
            app:endIconMode="password_toggle"
            app:endIconTint="?attr/colorOnSurfaceVariant">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAesPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:autofillHints="newPassword"
                android:imeOptions="actionDone"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ── Requisitos de la contraseña de wallet (5 puntos) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <!-- Req: 8+ chars -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/aesReqLengthIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_aes_length"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Req: mayúscula -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/aesReqUpperIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_upper"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Req: minúscula -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/aesReqLowerIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_lower"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Req: número -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/aesReqNumberIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_number"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>

            <!-- Req: símbolo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/aesReqSymbolIcon"
                    android:layout_width="20dp"
                    android:layout_height="wrap_content"
                    android:text="○"
                    android:textSize="14sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/reg_req_symbol"
                    android:textSize="13sp"
                    android:textColor="?attr/colorOnSurfaceVariant" />
            </LinearLayout>
        </LinearLayout>

        <!-- Error general -->
        <TextView
            android:id="@+id/tvAesError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="13sp"
            android:textColor="?attr/colorError"
            android:visibility="gone" />

        <!-- Botón Crear Wallet -->
        <Button
            android:id="@+id/btnCreateWallet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/reg_step4_btn"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnPrimary"
            android:backgroundTint="?attr/colorPrimary"
            android:enabled="false"
            android:stateListAnimator="@null"
            style="@style/Widget.Material3.Button"
            app:cornerRadius="28dp" />

        <!-- ProgressBar de creación -->
        <ProgressBar
            android:id="@+id/progressCreate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:indeterminateTint="?attr/colorPrimary"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
